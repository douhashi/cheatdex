{
	"$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": false,
		"includes": [
			"**",
			"!cloudflare-env.d.ts",
			"!next-env.d.ts",
			"!**/node_modules",
			"!**/.next",
			"!**/.open-next",
			"!apps/*/.output",
			"!apps/*/.wxt"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"domains": {
			"next": "recommended",
			"react": "recommended"
		},
		"rules": {
			"recommended": true
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"overrides": [
		{
			"includes": ["apps/extension/**"],
			"linter": {
				"domains": {
					"next": "none",
					"react": "none"
				}
			},
			"javascript": {
				"globals": ["__CHEATDEX_DEFAULT_BASE_URL__"]
			}
		}
	]
}
